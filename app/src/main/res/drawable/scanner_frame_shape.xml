<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer opaque rectangle -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" /> <!-- Semi-transparent black -->
            <size
                android:width="300dp"
                android:height="300dp"/>
        </shape>
    </item>

    <!-- Inner transparent rectangle -->
    <item
        android:left="20dp"
        android:right="20dp"
        android:top="20dp"
        android:bottom="20dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="2dp"
                android:color="#00FF00" /> <!-- Green border -->
        </shape>
    </item>
</layer-list>