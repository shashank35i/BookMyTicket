<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Transparent Background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" /> <!-- Fully transparent background -->
            <corners android:radius="0dp" />
        </shape>
    </item>
    <!-- Top-Left Corner: Horizontal Line -->
    <item android:right="260dp" android:bottom="300dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" /> <!-- White for PhonePe style -->
            <size android:width="50dp" android:height="6dp" /> <!-- Thick horizontal line -->
            <corners
                android:topLeftRadius="6dp"
                android:topRightRadius="6dp" />
        </shape>
    </item>
    <!-- Top-Left Corner: Vertical Line -->
    <item android:right="300dp" android:bottom="260dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
            <size android:width="6dp" android:height="50dp" /> <!-- Thick vertical line -->
            <corners
                android:topLeftRadius="6dp"
                android:bottomLeftRadius="6dp" />
        </shape>
    </item>
    <!-- Top-Right Corner: Horizontal Line -->
    <item android:left="260dp" android:bottom="300dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
            <size android:width="50dp" android:height="6dp" />
            <corners
                android:topLeftRadius="6dp"
                android:topRightRadius="6dp" />
        </shape>
    </item>
    <!-- Top-Right Corner: Vertical Line -->
    <item android:left="300dp" android:bottom="260dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
            <size android:width="6dp" android:height="50dp" />
            <corners
                android:topRightRadius="6dp"
                android:bottomRightRadius="6dp" />
        </shape>
    </item>
    <!-- Bottom-Left Corner: Horizontal Line -->
    <item android:right="260dp" android:top="300dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
            <size android:width="50dp" android:height="6dp" />
            <corners
                android:bottomLeftRadius="6dp"
                android:bottomRightRadius="6dp" />
        </shape>
    </item>
    <!-- Bottom-Left Corner: Vertical Line -->
    <item android:right="300dp" android:top="260dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
            <size android:width="6dp" android:height="50dp" />
            <corners
                android:topLeftRadius="6dp"
                android:bottomLeftRadius="6dp" />
        </shape>
    </item>
    <!-- Bottom-Right Corner: Horizontal Line -->
    <item android:left="260dp" android:top="300dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
            <size android:width="50dp" android:height="6dp" />
            <corners
                android:bottomLeftRadius="6dp"
                android:bottomRightRadius="6dp" />
        </shape>
    </item>
    <!-- Bottom-Right Corner: Vertical Line -->
    <item android:left="300dp" android:top="260dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
            <size android:width="6dp" android:height="50dp" />
            <corners
                android:topRightRadius="6dp"
                android:bottomRightRadius="6dp" />
        </shape>
    </item>
</layer-list>