<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- Background color -->
    <solid android:color="#BDBABA" />
    <!-- Rounded corners -->
    <corners android:radius="8dp" />
    <!-- Optional stroke (border) -->
    <stroke
        android:width="1dp"
        android:color="#C1C0C0" />
    <!-- Optional padding -->
    <padding
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp" />
</shape>