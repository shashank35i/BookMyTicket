<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Solid color for the button -->
    <solid android:color="#2196F3"/> <!-- Blue color -->

    <!-- Rounded corners -->
    <corners android:radius="8dp"/> <!-- Adjust the radius as needed -->

    <!-- Optional: Add padding if required -->
    <padding
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp"/>

    <!-- Optional: Add a stroke (border) -->
    <stroke
        android:width="1dp"
        android:color="#1976D2"/> <!-- Slightly darker blue for the border -->
</shape>