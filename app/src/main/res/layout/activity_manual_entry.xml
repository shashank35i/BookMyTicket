<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:padding="24dp">

    <!-- Back Button -->
    <ImageView
        android:id="@+id/back_button"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginTop="48dp"
        android:layout_marginStart="16dp"
        android:src="@drawable/ic_back"
        android:padding="12dp"
        android:background="@drawable/rounded_button_background"
        android:elevation="4dp"
        android:contentDescription="Back"
        app:tint="@android:color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Title -->
    <TextView
        android:id="@+id/txt_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Manual Vehicle Entry"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:textColor="@android:color/black"
        android:elevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/back_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Vehicle Number Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_vehicle_number"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginHorizontal="16dp"
        app:hintTextAppearance="@style/TextAppearance.AppCompat.Medium"
        app:boxBackgroundMode="filled"
        app:boxBackgroundColor="@android:color/white"
        app:boxStrokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/txt_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/vehicle_number_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Vehicle Number (e.g., MH12AB1234)"
            android:inputType="textCapCharacters"
            android:maxLength="10"
            android:textColorHint="@color/premium_dark_purple"
            android:fontFamily="sans-serif"
            android:textSize="16sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Confirm Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/confirm_button"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="32dp"
        android:text="Confirm"
        android:textSize="16sp"
        android:fontFamily="sans-serif-medium"
        app:cornerRadius="16dp"
        app:backgroundTint="@color/primary_purple"
        app:rippleColor="@color/premium_dark_purple"
        app:layout_constraintTop_toBottomOf="@id/til_vehicle_number"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Cancel Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/cancel_button"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:text="Cancel"
        android:textSize="16sp"
        android:fontFamily="sans-serif-medium"
        app:cornerRadius="16dp"
        app:backgroundTint="@android:color/darker_gray"
        app:rippleColor="@color/gray"
        app:layout_constraintTop_toBottomOf="@id/confirm_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>