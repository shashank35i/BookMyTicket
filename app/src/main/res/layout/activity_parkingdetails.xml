<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/custom_header"
        android:layout_width="match_parent"
        android:layout_height="69dp"
        android:orientation="horizontal"
        android:padding="20dp"
        android:background="#FFFFFF"
        android:elevation="6dp"
        android:clipToPadding="false">

        <ImageView
            android:id="@+id/back_button"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_back"
            android:contentDescription="Back"
            android:layout_marginEnd="20dp"
            app:tint="#333333"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Parking Details Setup"
            android:textColor="#1A1A1A"
            android:textSize="20sp"
            android:fontFamily="@font/poppins_bold" />
    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/custom_header"
        android:layout_above="@id/submit_button"
        android:paddingHorizontal="0dp"
        android:paddingTop="0dp"
        android:paddingBottom="5dp"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/inputFields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_white_bg"
            android:padding="24dp">

            <!-- Description -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enter parking area details and pricing for different vehicle types. These will be used for payment calculations."
                android:textSize="14sp"
                android:textColor="#4A4A4A"
                android:fontFamily="@font/poppins_regular"
                android:paddingBottom="12dp"
                android:lineSpacingExtra="4dp" />

            <!-- Parking Area -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Parking Area"
                android:textSize="14sp"
                android:textColor="#1A1A1A"
                android:fontFamily="@font/poppins_medium"
                android:paddingTop="16dp"
                android:paddingBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/parking_area_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter parking area name (e.g., Main Lot)"
                app:hintTextColor="#A0A0A0"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="#4CAF50"
                app:boxStrokeWidth="1dp"
                android:textColorHint="#A6A5A5"
                app:boxStrokeWidthFocused="2dp"
                app:boxBackgroundColor="#FFFFFF"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/parking_area"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:inputType="text"
                    android:textColor="#1A1A1A"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_regular"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Car Parking Price -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Car Parking Price"
                android:textSize="14sp"
                android:textColor="#1A1A1A"
                android:fontFamily="@font/poppins_medium"
                android:paddingTop="16dp"
                android:paddingBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/car_parking_price_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter price for cars (e.g., ₹50.00)"
                app:hintTextColor="#A0A0A0"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="#4CAF50"
                app:boxStrokeWidth="1dp"
                android:textColorHint="#A6A5A5"
                app:boxStrokeWidthFocused="2dp"
                app:boxBackgroundColor="#FFFFFF"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/car_parking_price"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:inputType="numberDecimal"
                    android:textColor="#1A1A1A"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_regular"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Bike Parking Price -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bike Parking Price"
                android:textSize="14sp"
                android:textColor="#1A1A1A"
                android:fontFamily="@font/poppins_medium"
                android:paddingTop="16dp"
                android:paddingBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/bike_parking_price_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter price for bikes (e.g., ₹20.00)"
                app:hintTextColor="#A0A0A0"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="#4CAF50"
                app:boxStrokeWidth="1dp"
                android:textColorHint="#A6A5A5"
                app:boxStrokeWidthFocused="2dp"
                app:boxBackgroundColor="#FFFFFF"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/bike_parking_price"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:inputType="numberDecimal"
                    android:textColor="#1A1A1A"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_regular"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Bus Parking Price -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bus Parking Price"
                android:textSize="14sp"
                android:textColor="#1A1A1A"
                android:fontFamily="@font/poppins_medium"
                android:paddingTop="16dp"
                android:paddingBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/bus_parking_price_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter price for buses (e.g., ₹100.00)"
                app:hintTextColor="#A0A0A0"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="#4CAF50"
                app:boxStrokeWidth="1dp"
                android:textColorHint="#A6A5A5"
                app:boxStrokeWidthFocused="2dp"
                app:boxBackgroundColor="#FFFFFF"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/bus_parking_price"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:inputType="numberDecimal"
                    android:textColor="#1A1A1A"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_regular"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Continue Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/submit_button"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="24dp"
        android:text="Continue"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:fontFamily="@font/poppins_bold"
        app:backgroundTint="#2E2E2E"
        app:cornerRadius="12dp"
        app:strokeColor="#E0E0E0"
        app:strokeWidth="1dp"
        app:rippleColor="#4A4A4A" />
</RelativeLayout>