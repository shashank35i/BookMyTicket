<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F6F5">

    <!-- Modern Header with Gradient -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:background="@drawable/header_gradient"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:transitionName="header_transition">

        <ImageView
            android:id="@+id/back_button"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginTop="28dp"
            android:src="@drawable/ic_back"
            app:tint="#FFFFFF"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:layout_marginTop="28dp"
            android:text="Your Tickets"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:fontFamily="@font/poppins_bold"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Filter and Sort Section -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/filter_chip_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="1dp"
        android:background="#FFFFFF"
        android:padding="6dp"
        app:chipSpacingHorizontal="8dp"
        app:singleLine="true"
        android:elevation="2dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/sort_button"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:text="Newest First"
            android:fontFamily="@font/poppins_regular"
            android:textColor="@color/sort_button_text"
            android:textSize="14sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:icon="@drawable/ic_sort"
            app:iconSize="18dp"
            app:iconPadding="6dp"
            app:iconGravity="textStart"
            app:iconTint="@color/sort_button_icon"
            app:strokeColor="@color/sort_button_stroke"
            app:strokeWidth="1dp"
            app:rippleColor="@color/sort_button_ripple"
            app:backgroundTint="@color/sort_button_background"
            app:cornerRadius="8dp"
            android:elevation="1dp" />

    </com.google.android.material.chip.ChipGroup>

    <!-- Content Area -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="3dp"
            android:paddingTop="2dp">

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/empty_state"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:elevation="2dp">

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_marginBottom="12dp"
                    android:src="@drawable/ic_empty_tickets"
                    app:tint="#6B7280" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="No Tickets Found"
                    android:textColor="#1F2A44"
                    android:textSize="18sp"
                    android:fontFamily="@font/poppins_bold"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="Start exploring amazing places!"
                    android:textColor="#6B7280"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_regular" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/explore_button"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:text="Explore Now"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/poppins_medium"
                    app:backgroundTint="@color/primary_color"
                    app:cornerRadius="12dp"
                    app:rippleColor="@color/primary_color_ripple"
                    android:paddingHorizontal="24dp" />
            </LinearLayout>

            <!-- Tickets Container -->
            <LinearLayout
                android:id="@+id/tickets_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminateTint="@color/primary_color" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>