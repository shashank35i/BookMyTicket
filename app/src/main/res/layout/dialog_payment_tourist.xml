<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="340dp"
    android:layout_height="wrap_content"
    android:background="@drawable/rounded_dialog_background"
    android:padding="20dp"
    android:elevation="10dp">

    <!-- Title -->
    <TextView
        android:id="@+id/txt_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Payment Request"
        android:textColor="#1A1A1A"
        android:textSize="18sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Vehicle Number -->
    <TextView
        android:id="@+id/txt_vehicle_number"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/rounded_background_light"
        android:gravity="center"
        android:padding="12dp"
        android:textColor="#1A1A1A"
        android:textSize="15sp"
        android:fontFamily="sans-serif"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txt_title" />

    <!-- Payment Amount -->
    <TextView
        android:id="@+id/txt_payment_amount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/rounded_background_light"
        android:gravity="center"
        android:padding="12dp"
        android:text="₹100.00"
        android:textColor="#1A1A1A"
        android:textSize="15sp"
        android:fontFamily="sans-serif"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txt_vehicle_number" />

    <!-- Accept Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_accept"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="8dp"
        android:backgroundTint="#0052CC"
        android:text="Accept"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        app:cornerRadius="8dp"
        app:rippleColor="#4D82F7"
        app:layout_constraintEnd_toStartOf="@id/btn_deny"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txt_payment_amount" />

    <!-- Deny Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_deny"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="8dp"
        android:backgroundTint="#F64F4F"
        android:text="Deny"
        android:textColor="#FBFBFB"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        app:cornerRadius="8dp"
        app:rippleColor="#B0BEC5"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btn_accept"
        app:layout_constraintTop_toBottomOf="@id/txt_payment_amount" />

</androidx.constraintlayout.widget.ConstraintLayout>