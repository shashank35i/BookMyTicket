<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/backButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="Back"
            android:padding="12dp"
            android:src="@drawable/ic_back"
            app:tint="#1E3A8A" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:layout_marginEnd="40dp"
            android:text="Manage Bank Details"
            android:fontFamily="@font/poppins_bold"
            android:textColor="#1E3A8A"
            android:textSize="22sp" />
    </LinearLayout>

    <!-- Main Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingHorizontal="32dp"
        android:paddingTop="32dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:id="@+id/inputFields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Account Holder -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Account Holder Name"
                android:fontFamily="@font/poppins_medium"
                android:textColor="#4B5563"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/editAccountHolder"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/edit_text_professional"
                android:hint="Enter account holder name"
                android:inputType="textPersonName"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:fontFamily="@font/poppins_regular"
                android:textColor="#111827"
                android:textColorHint="#9CA3AF"
                android:textSize="16sp" />

            <!-- Account Number -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="20dp"
                android:text="Account Number"
                android:fontFamily="@font/poppins_medium"
                android:textColor="#4B5563"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/editAccountNumber"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/edit_text_professional"
                android:hint="Enter account number"
                android:inputType="number"
                android:longClickable="false"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:fontFamily="@font/poppins_regular"
                android:textColor="#111827"
                android:textColorHint="#9CA3AF"
                android:textSize="16sp" />

            <!-- Re-enter Account Number -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="20dp"
                android:text="Re-enter Account Number"
                android:fontFamily="@font/poppins_medium"
                android:textColor="#4B5563"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/editReEnterAccountNumber"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/edit_text_professional"
                android:hint="Re-enter account number"
                android:inputType="numberPassword"
                android:longClickable="false"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:fontFamily="@font/poppins_regular"
                android:textColor="#111827"
                android:textColorHint="#9CA3AF"
                android:textSize="16sp" />

            <!-- IFSC Code -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="20dp"
                android:text="IFSC Code"
                android:fontFamily="@font/poppins_medium"
                android:textColor="#4B5563"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/editIFSC"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/edit_text_professional"
                android:hint="Enter IFSC code"
                android:inputType="textCapCharacters"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:fontFamily="@font/poppins_regular"
                android:textColor="#111827"
                android:textColorHint="#9CA3AF"
                android:textSize="16sp" />

            <!-- Save Button -->
            <Button
                android:id="@+id/btnSaveBankDetails"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/rounded_bg"
                android:text="Save Bank Details"
                android:fontFamily="@font/poppins_bold"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:elevation="4dp"
                />
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>