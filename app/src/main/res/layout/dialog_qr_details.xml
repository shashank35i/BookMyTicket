<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    android:id="@+id/scroll_view"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:scrollbars="none"
    android:background="@color/premium_dialog_bg"
    android:fillViewport="false"
    android:overScrollMode="never">

    <LinearLayout
        android:id="@+id/root_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/dialog_padding"
        android:background="@color/premium_dialog_bg"
        android:minHeight="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/section_spacing">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="0dp">

                <TextView
                    android:id="@+id/dialog_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="QR DETAILS"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_size_title"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:fontFamily="@font/poppins_bold"
                    android:paddingHorizontal="@dimen/title_padding_horizontal"
                    android:paddingVertical="@dimen/title_padding_vertical"
                    android:background="@drawable/bg_rounded_accent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/close_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="@dimen/close_button_size"
                    android:minHeight="@dimen/close_button_size"
                    android:layout_marginStart="0dp"
                    app:icon="@drawable/ic_close"
                    app:iconSize="@dimen/icon_size_large"
                    android:background="@android:color/transparent"
                    app:iconTint="@color/white"
                    android:backgroundTint="@android:color/transparent"
                    app:cornerRadius="@dimen/button_corner_radius"
                    app:rippleColor="@color/accent_dark"
                    app:strokeWidth="1dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/card_margin_bottom"
            app:cardBackgroundColor="@color/card_bg_dark"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:strokeColor="@color/white_30"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="10dp"
                    android:paddingBottom="@dimen/section_spacing">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PLACE NAME"
                        android:textColor="@color/accent_light"
                        android:textSize="@dimen/text_size_label"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"
                        android:fontFamily="@font/poppins_medium"/>

                    <TextView
                        android:id="@+id/place_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_size_value"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:fontFamily="@font/poppins_regular"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="@dimen/section_spacing">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Entry Time: "
                        android:textColor="@color/accent_light"
                        android:textSize="@dimen/text_size_label"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"
                        android:fontFamily="@font/poppins_medium"/>

                    <TextView
                        android:id="@+id/entry_time"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white_90"
                        android:textSize="@dimen/text_size_value"
                        android:maxLines="2"
                        android:ellipsize="none"
                        android:lineSpacingExtra="2dp"
                        android:fontFamily="@font/poppins_regular"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="@dimen/section_spacing">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="INSTRUCTIONS"
                        android:textColor="@color/accent_light"
                        android:textSize="@dimen/text_size_label"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"
                        android:fontFamily="@font/poppins_medium"/>

                    <TextView
                        android:id="@+id/instructions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/text_margin_top"
                        android:textColor="@color/white_90"
                        android:textSize="@dimen/text_size_value"
                        android:maxLines="4"
                        android:ellipsize="end"
                        android:fontFamily="@font/poppins_regular"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingTop="@dimen/section_spacing">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/text_margin_bottom"
                            android:text="CONTACT"
                            android:textColor="@color/accent_light"
                            android:textSize="@dimen/text_size_label"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1"
                            android:fontFamily="@font/poppins_medium"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="@dimen/icon_size_small"
                                android:layout_height="@dimen/icon_size_small"
                                android:layout_marginEnd="@dimen/icon_margin_end"
                                android:src="@drawable/ic_phone"
                                app:tint="@color/accent_light"/>

                            <TextView
                                android:id="@+id/helpline"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:textColor="@color/white"
                                android:textSize="@dimen/text_size_value"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:fontFamily="@font/poppins_regular"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/card_margin_bottom"
            app:cardBackgroundColor="@color/card_bg_dark"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:strokeColor="@color/white_30"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/text_margin_bottom"
                    android:text="TICKET PRICES BREAKDOWN"
                    android:textColor="@color/accent_light"
                    android:textSize="@dimen/text_size_label"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:fontFamily="@font/poppins_medium"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/text_margin_bottom"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Adults"
                        android:textColor="@color/white_70"
                        android:textSize="@dimen/text_size_value"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/poppins_regular"/>

                    <TextView
                        android:id="@+id/adults_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_size_value"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/poppins_regular"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/text_margin_bottom"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Students"
                        android:textColor="@color/white_70"
                        android:textSize="@dimen/text_size_value"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/poppins_regular"/>

                    <TextView
                        android:id="@+id/students_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_size_value"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/poppins_regular"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/text_margin_bottom"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Children"
                        android:textColor="@color/white_70"
                        android:textSize="@dimen/text_size_value"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/poppins_regular"/>

                    <TextView
                        android:id="@+id/children_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_size_value"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/poppins_regular"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/text_margin_bottom"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Senior Citizens"
                        android:textColor="@color/white_70"
                        android:textSize="@dimen/text_size_value"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/poppins_regular"/>

                    <TextView
                        android:id="@+id/senior_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_size_value"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/poppins_regular"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Camera Fee"
                        android:textColor="@color/white_70"
                        android:textSize="@dimen/text_size_value"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/poppins_regular"/>

                    <TextView
                        android:id="@+id/camera_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_size_value"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/poppins_regular"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/card_margin_bottom"
            app:cardBackgroundColor="@color/card_bg_dark"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:strokeColor="@color/white_30"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/text_margin_bottom"
                    android:text="ACCOUNT INFORMATION"
                    android:textColor="@color/accent_light"
                    android:textSize="@dimen/text_size_label"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:fontFamily="@font/poppins_medium"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/text_margin_bottom"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Bank Name"
                        android:textColor="@color/white_70"
                        android:textSize="@dimen/text_size_value"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/poppins_regular"/>

                    <TextView
                        android:id="@+id/bank_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_size_value"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/poppins_regular"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/text_margin_bottom"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Account Number"
                        android:textColor="@color/white_70"
                        android:textSize="@dimen/text_size_value"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/poppins_regular"/>

                    <TextView
                        android:id="@+id/bank_account_number"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_size_value"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/poppins_regular"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Email ID"
                        android:textColor="@color/white_70"
                        android:textSize="@dimen/text_size_value"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/poppins_regular"/>

                    <TextView
                        android:id="@+id/email_id"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_size_value"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/poppins_regular"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <FrameLayout
            android:id="@+id/download_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/button_height"
            android:layout_marginHorizontal="@dimen/button_margin_horizontal"
            android:layout_marginBottom="@dimen/button_margin_bottom"
            android:background="@drawable/buttonj_background"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/button_height"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingStart="@dimen/button_padding_start"
                android:paddingEnd="@dimen/button_padding_end">

                <ImageView
                    android:layout_width="@dimen/icon_size_medium"
                    android:layout_height="@dimen/icon_size_medium"
                    android:layout_marginStart="@dimen/icon_margin_start"
                    android:layout_marginEnd="@dimen/icon_margin_end"
                    android:src="@android:drawable/stat_sys_download"
                    app:tint="@color/white"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Download QR Code"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_size_button"
                    android:singleLine="false"
                    android:maxLines="1"
                    android:ellipsize="none"
                    android:fontFamily="@font/poppins_medium"/>
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</ScrollView>