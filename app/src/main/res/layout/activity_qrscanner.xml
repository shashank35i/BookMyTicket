<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#F5F5F5">

    <!-- Header with Material Design -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="#1A1A1A"
        android:elevation="4dp"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="@null">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:orientation="horizontal"
            android:paddingEnd="16dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back"
                android:contentDescription="Back"
                android:layout_marginTop="23dp"
                app:tint="#FFFFFF"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="25dp"
                android:text="Scan QR Code"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:fontFamily="@font/poppins_bold"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Scanner Section -->
    <FrameLayout
        android:id="@+id/scanner_section"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:background="#000000">

        <androidx.camera.view.PreviewView
            android:id="@+id/camera_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <FrameLayout
            android:id="@+id/scanner_frame"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:layout_gravity="center"
            android:background="@drawable/scanner_frame_bg"
            app:cardElevation="8dp">

            <ImageView
                android:id="@+id/scanner_border"
                android:layout_width="250dp"
                android:layout_height="250dp"
                android:layout_gravity="center"
                android:src="@drawable/scanner_border_animated"
                android:visibility="visible" />
        </FrameLayout>

        <ImageView
            android:id="@+id/scan_laser"
            android:layout_width="280dp"
            android:layout_height="11dp"
            android:layout_gravity="center"
            android:src="@drawable/laser_line_gradient"
            android:visibility="gone"
            android:elevation="6dp" />

        <ImageView
            android:id="@+id/scan_success"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_check_circle"
            android:visibility="gone"
            app:tint="#4CAF50"
            android:elevation="8dp" />
    </FrameLayout>

    <!-- Bottom Guidance -->
    <LinearLayout
        android:id="@+id/bottom_guidance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_margin="24dp"
        android:background="@drawable/bg_rounded_card"
        android:orientation="vertical"
        android:padding="16dp"
        android:elevation="4dp">

        <TextView
            android:id="@+id/scan_instructions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Align the QR code within the frame"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/scanner_border"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Scanning will start automatically"
            android:textAlignment="center"
            android:textColor="#B0B0B0"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_regular" />
    </LinearLayout>

    <!-- Number of Persons Bottom Sheet -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/number_of_persons_section"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignParentBottom="true"
        android:visibility="gone"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <com.google.android.material.appbar.MaterialToolbar
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="#2E7D32"
                app:titleTextColor="#FFFFFF"
                app:navigationIcon="@null">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/btn_back_persons"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_back"
                        android:layout_marginTop="25dp"
                        android:contentDescription="Back"
                        app:tint="#FFFFFF"
                        android:background="?attr/selectableItemBackgroundBorderless" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Enter Number of Persons"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:layout_marginTop="25dp"
                        android:fontFamily="@font/poppins_bold"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.appbar.MaterialToolbar>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="20dp"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/labelAdults"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Adults"
                            android:textColor="#424242"
                            android:textSize="16sp"
                            android:fontFamily="@font/poppins_medium"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <LinearLayout
                            android:id="@+id/pickerAdults"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_number_picker"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:padding="8dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <ImageView
                                android:id="@+id/btnDecreaseAdults"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginEnd="12dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Decrease"
                                android:src="@drawable/ic_remove"
                                app:tint="#424242" />

                            <TextView
                                android:id="@+id/txtAdults"
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="0"
                                android:textColor="#212121"
                                android:textSize="16sp"
                                android:fontFamily="@font/poppins_medium" />

                            <ImageView
                                android:id="@+id/btnIncreaseAdults"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginStart="12dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Increase"
                                android:src="@drawable/ic_add"
                                app:tint="#424242" />
                        </LinearLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/labelStudents"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Students"
                            android:textColor="#424242"
                            android:textSize="16sp"
                            android:fontFamily="@font/poppins_medium"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <LinearLayout
                            android:id="@+id/pickerStudents"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_number_picker"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:padding="8dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <ImageView
                                android:id="@+id/btnDecreaseStudents"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginEnd="12dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Decrease"
                                android:src="@drawable/ic_remove"
                                app:tint="#424242" />

                            <TextView
                                android:id="@+id/txtStudents"
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="0"
                                android:textColor="#212121"
                                android:textSize="16sp"
                                android:fontFamily="@font/poppins_medium" />

                            <ImageView
                                android:id="@+id/btnIncreaseStudents"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginStart="12dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Increase"
                                android:src="@drawable/ic_add"
                                app:tint="#424242" />
                        </LinearLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/labelChildren"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Children"
                            android:textColor="#424242"
                            android:textSize="16sp"
                            android:fontFamily="@font/poppins_medium"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <LinearLayout
                            android:id="@+id/pickerChildren"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_number_picker"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:padding="8dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <ImageView
                                android:id="@+id/btnDecreaseChildren"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginEnd="12dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Decrease"
                                android:src="@drawable/ic_remove"
                                app:tint="#424242" />

                            <TextView
                                android:id="@+id/txtChildren"
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="0"
                                android:textColor="#212121"
                                android:textSize="16sp"
                                android:fontFamily="@font/poppins_medium" />

                            <ImageView
                                android:id="@+id/btnIncreaseChildren"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginStart="12dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Increase"
                                android:src="@drawable/ic_add"
                                app:tint="#424242" />
                        </LinearLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/labelSeniorCitizens"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Senior Citizens"
                            android:textColor="#424242"
                            android:textSize="16sp"
                            android:fontFamily="@font/poppins_medium"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <LinearLayout
                            android:id="@+id/pickerSeniorCitizens"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_number_picker"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:padding="8dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <ImageView
                                android:id="@+id/btnDecreaseSeniorCitizens"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginEnd="12dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Decrease"
                                android:src="@drawable/ic_remove"
                                app:tint="#424242" />

                            <TextView
                                android:id="@+id/txtSeniorCitizens"
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="0"
                                android:textColor="#212121"
                                android:textSize="16sp"
                                android:fontFamily="@font/poppins_medium" />

                            <ImageView
                                android:id="@+id/btnIncreaseSeniorCitizens"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginStart="12dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Increase"
                                android:src="@drawable/ic_add"
                                app:tint="#424242" />
                        </LinearLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="50dp">

                        <TextView
                            android:id="@+id/labelCameras"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Cameras"
                            android:textColor="#424242"
                            android:textSize="16sp"
                            android:fontFamily="@font/poppins_medium"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <LinearLayout
                            android:id="@+id/pickerCameras"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_number_picker"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:padding="8dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <ImageView
                                android:id="@+id/btnDecreaseCameras"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginEnd="12dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Decrease"
                                android:src="@drawable/ic_remove"
                                app:tint="#424242" />

                            <TextView
                                android:id="@+id/txtCameras"
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="0"
                                android:textColor="#212121"
                                android:textSize="16sp"
                                android:fontFamily="@font/poppins_medium" />

                            <ImageView
                                android:id="@+id/btnIncreaseCameras"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginStart="12dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Increase"
                                android:src="@drawable/ic_add"
                                app:tint="#424242" />
                        </LinearLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnContinue"
                        android:layout_width="match_parent"
                        android:layout_height="66dp"
                        android:layout_margin="24dp"
                        android:text="Continue"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:fontFamily="@font/poppins_bold"
                        android:textStyle="bold"
                        app:backgroundTint="#2E7D32"
                        app:cornerRadius="12dp"
                        app:icon="@drawable/ic_arrow_right"
                        app:iconGravity="end"
                        app:iconTint="#FFFFFF"
                        app:strokeColor="#2E7D32" />
                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Payment Section Bottom Sheet -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/payment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignParentBottom="true"
        app:cardBackgroundColor="#FFFFFF"
        android:visibility="gone"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/header_qr"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="#2E7D32"
                app:titleTextColor="#FFFFFF"
                app:navigationIcon="@null">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:orientation="horizontal"
                    android:paddingEnd="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/btn_back_payment"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="Back"
                        android:layout_marginTop="25dp"
                        android:src="@drawable/ic_back"
                        app:tint="#FFFFFF"
                        android:background="?attr/selectableItemBackgroundBorderless" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="25dp"
                        android:text="Payment Summary"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:fontFamily="@font/poppins_bold"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.appbar.MaterialToolbar>

            <ScrollView
                android:id="@+id/scroll_view_payment"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:padding="24dp">

                <LinearLayout
                    android:id="@+id/qr_payment_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="Ticket Summary"
                        android:textColor="#212121"
                        android:textSize="18sp"
                        android:fontFamily="@font/poppins_bold"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/adultsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Adults"
                            android:textColor="#757575"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_regular" />

                        <TextView
                            android:id="@+id/txtAdultsSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#212121"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_medium" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/studentsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Students"
                            android:textColor="#757575"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_regular" />

                        <TextView
                            android:id="@+id/txtStudentsSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#212121"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_medium" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/childrenContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Children"
                            android:textColor="#757575"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_regular" />

                        <TextView
                            android:id="@+id/txtChildrenSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#212121"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_medium" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/seniorCitizensContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Senior Citizens"
                            android:textColor="#757575"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_regular" />

                        <TextView
                            android:id="@+id/txtSeniorCitizensSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#212121"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_medium" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/camerasContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Cameras"
                            android:textColor="#757575"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_regular" />

                        <TextView
                            android:id="@+id/txtCamerasSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#212121"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_medium" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Ticket(s) price"
                            android:textColor="#757575"
                            android:textSize="16sp"
                            android:fontFamily="@font/poppins_regular" />

                        <TextView
                            android:id="@+id/txtTicketPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹0.00"
                            android:textColor="#212121"
                            android:textSize="16sp"
                            android:fontFamily="@font/poppins_bold"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/txtConvenienceFees"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Convenience fees"
                                android:textColor="#757575"
                                android:textSize="16sp"
                                android:fontFamily="@font/poppins_regular" />

                            <ImageView
                                android:id="@+id/imgDownArrow"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_expand_more"
                                app:tint="#757575" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/feeDetails"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="16dp"
                            android:paddingBottom="16dp"
                            android:visibility="gone">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="8dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Platform Fee"
                                    android:textColor="#757575"
                                    android:textSize="14sp"
                                    android:fontFamily="@font/poppins_regular" />

                                <TextView
                                    android:id="@+id/txtPlatformFee"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₹0.00"
                                    android:textColor="#212121"
                                    android:textSize="14sp"
                                    android:fontFamily="@font/poppins_medium" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Integrated GST (IGST) @ 18%"
                                    android:textColor="#757575"
                                    android:textSize="14sp"
                                    android:fontFamily="@font/poppins_regular" />

                                <TextView
                                    android:id="@+id/txtGST"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₹0.00"
                                    android:textColor="#212121"
                                    android:textSize="14sp"
                                    android:fontFamily="@font/poppins_medium" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="16dp"
                        android:background="#E0E0E0" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Order Total"
                            android:textColor="#212121"
                            android:textSize="18sp"
                            android:fontFamily="@font/poppins_bold"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtTotalAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹0.00"
                            android:textColor="#2E7D32"
                            android:textSize="18sp"
                            android:fontFamily="@font/poppins_bold"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtNonRefundableNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Note: Tickets once purchased are non-refundable."
                        android:textColor="#565555"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins_regular"
                        android:layout_marginBottom="16dp" />
                </LinearLayout>
            </ScrollView>

            <FrameLayout
                android:id="@+id/swipe_container"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="54dp"
                android:layout_marginStart="35dp"
                android:layout_marginEnd="35dp"
                android:background="@drawable/bg_swipe_container"
                android:elevation="6dp"
                app:cardCornerRadius="12dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_swipe_track"
                    android:alpha="0.9" />

                <ProgressBar
                    android:id="@+id/swipe_progress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="invisible"
                    android:progressTint="@color/zxing_transparent" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/swipe_thumb"
                    android:layout_width="56dp"
                    android:layout_height="match_parent"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="4dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="#2E7D32" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/swipe_text"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:paddingEnd="16dp"
                    android:text="Swipe to pay"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_bold"
                    android:textStyle="bold" />
            </FrameLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</RelativeLayout>