<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="24dp"
    android:background="@drawable/rounded_dialog_background"
    android:layout_gravity="center"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="16dp"
    android:elevation="6dp">

    <!-- Title -->
    <TextView
        android:id="@+id/txt_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Confirm Payment"
        android:textColor="#1A1A1A"
        android:textSize="20sp"
        android:fontFamily="@font/poppins_bold"
        android:textAlignment="center"
        android:paddingBottom="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Vehicle Number -->
    <TextView
        android:id="@+id/txt_vehicle_number"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Vehicle: Fetching..."
        android:textColor="#424242"
        android:textSize="15sp"
        android:fontFamily="@font/poppins_medium"
        android:paddingVertical="10dp"
        android:background="@drawable/rounded_field_background"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/txt_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Owner UID -->
    <TextView
        android:id="@+id/txt_owner_uid"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="UID: Fetching..."
        android:textColor="#424242"
        android:textSize="15sp"
        android:fontFamily="@font/poppins_medium"
        android:paddingVertical="10dp"
        android:background="@drawable/rounded_field_background"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/txt_vehicle_number"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Vehicle Type -->
    <TextView
        android:id="@+id/txt_vehicle_type"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Vehicle Type: Fetching..."
        android:textColor="#424242"
        android:textSize="15sp"
        android:fontFamily="@font/poppins_medium"
        android:paddingVertical="10dp"
        android:background="@drawable/rounded_field_background"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/txt_owner_uid"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Owner Phone -->
    <TextView
        android:id="@+id/txt_owner_phone"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Phone: Fetching..."
        android:textColor="#424242"
        android:textSize="15sp"
        android:fontFamily="@font/poppins_medium"
        android:paddingVertical="10dp"
        android:background="@drawable/rounded_field_background"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/txt_vehicle_type"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Payment Amount -->
    <TextView
        android:id="@+id/txt_payment_amount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Amount: Fetching..."
        android:textColor="#424242"
        android:textSize="15sp"
        android:fontFamily="@font/poppins_medium"
        android:paddingVertical="10dp"
        android:background="@drawable/rounded_field_background"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/txt_owner_phone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Error Message -->
    <TextView
        android:id="@+id/txt_error_message"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Error"
        android:textColor="#EF4444"
        android:textSize="14sp"
        android:fontFamily="@font/poppins_regular"
        android:visibility="gone"
        android:paddingVertical="10dp"
        app:layout_constraintTop_toBottomOf="@id/txt_payment_amount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Manual Entry Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_manual_entry"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/txt_error_message"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:boxBackgroundColor="#F8FAFC"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusTopStart="12dp"
        app:hintTextColor="#6B7280">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_manual_entry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter vehicle number"
            android:inputType="text"
            android:textColor="#1A1A1A"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_regular" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Edit Buttons Container -->
    <LinearLayout
        android:id="@+id/edit_buttons_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/til_manual_entry"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_edit_manual"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:text="Edit Vehicle Number"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_medium"
            android:backgroundTint="#2DD4BF"
            app:cornerRadius="8dp"
            app:rippleColor="#5EEAD4"
            android:visibility="visible" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel_edit"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:text="Cancel"
            android:textColor="#EF4444"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_medium"
            android:background="@drawable/outline_button_red"
            android:visibility="gone"
            app:cornerRadius="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_edit"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:text="Save"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_medium"
            android:background="@drawable/gradient_button_blue"
            android:visibility="gone"
            app:cornerRadius="8dp" />
    </LinearLayout>

    <!-- Confirm and Cancel Buttons -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_confirm"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="12dp"
        android:text="Confirm"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:fontFamily="@font/poppins_medium"
        android:background="@drawable/gradient_button_blue"
        android:elevation="4dp"
        app:cornerRadius="8dp"
        app:layout_constraintTop_toBottomOf="@id/edit_buttons_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_cancel"
        app:layout_constraintHorizontal_weight="1.5"
        app:layout_constraintHorizontal_chainStyle="spread" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_cancel"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="12dp"
        android:text="Cancel"
        android:textColor="#0066FF"
        android:textSize="15sp"
        android:fontFamily="@font/poppins_medium"
        android:background="@drawable/outline_button_blue"
        app:cornerRadius="8dp"
        app:layout_constraintTop_toBottomOf="@id/edit_buttons_container"
        app:layout_constraintStart_toEndOf="@id/btn_confirm"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_weight="1" />
</androidx.constraintlayout.widget.ConstraintLayout>