<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="top"
    android:background="@color/background_light"
    tools:context=".TouristProfileActivity">

    <!-- Header with Back Button -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/white"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="4dp"
        android:translationZ="4dp">

        <ImageView
            android:id="@+id/back_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            app:tint="@color/primary_blue"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Profile"
            android:textColor="@color/primary_blue"
            android:textSize="20sp"
            android:fontFamily="@font/poppins_bold"
            android:layout_centerInParent="true" />
    </RelativeLayout>

    <!-- Profile Image Section with Shimmer -->
    <com.facebook.shimmer.ShimmerFrameLayout
        android:id="@+id/profile_shimmer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:padding="20dp"
        app:shimmer_duration="1000"
        app:shimmer_intensity="0.35">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/profile_image"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_profile"
                android:background="@drawable/circle_profileback"
                android:padding="3dp"
                app:strokeWidth="3dp"
                app:strokeColor="@color/primary_blue"
                app:shapeAppearance="@style/FullCircleShape"
                android:elevation="0dp"
                android:translationZ="2dp"
                android:contentDescription="Profile Picture" />

            <ImageView
                android:id="@+id/update_profile"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_edit"
                android:background="@drawable/circle_accent_background"
                android:padding="5dp"
                android:translationZ="10dp"
                android:layout_alignBottom="@id/profile_image"
                android:layout_alignEnd="@id/profile_image"
                android:layout_marginBottom="8dp"
                android:layout_marginEnd="8dp"
                app:tint="@color/white"
                android:backgroundTint="@color/accent_orange"
                android:contentDescription="Edit Profile"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone" />
        </RelativeLayout>
    </com.facebook.shimmer.ShimmerFrameLayout>

    <!-- User Details Section with Shimmer -->
    <com.facebook.shimmer.ShimmerFrameLayout
        android:id="@+id/details_shimmer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        app:shimmer_duration="1000"
        app:shimmer_intensity="0.35">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/card_backgrounds"
            android:elevation="0dp"
            android:translationZ="4dp">

            <TextView
                android:id="@+id/user_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User ID: Loading..."
                android:textSize="16sp"
                android:textColor="@color/primary_text"
                android:fontFamily="@font/poppins_medium"
                android:paddingBottom="12dp"
                android:drawableStart="@drawable/ic_profile"
                android:drawablePadding="10dp"
                android:drawableTint="@color/primary_blue" />

            <TextView
                android:id="@+id/phone_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phone Number: Loading..."
                android:textSize="14sp"
                android:textColor="@color/secondary_text"
                android:fontFamily="@font/poppins_regular"
                android:paddingBottom="12dp"
                android:drawableStart="@drawable/ic_phone"
                android:drawablePadding="10dp"
                android:drawableTint="@color/primary_blue" />
        </LinearLayout>
    </com.facebook.shimmer.ShimmerFrameLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@drawable/gradient_divider"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp" />

    <!-- Favorite Destinations Section -->
    <LinearLayout
        android:id="@+id/favorite_destinations_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@drawable/card_backgrounds"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:elevation="1dp"
        android:translationZ="4dp"
        android:backgroundTint="@color/white"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_favorite"
            android:layout_marginEnd="12dp"
            app:tint="@color/primary_blue"
            android:contentDescription="Favorite Destinations" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Favorite Destinations"
                android:textSize="16sp"
                android:textColor="@color/primary_text"
                android:fontFamily="@font/poppins_medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View your saved travel spots"
                android:textSize="12sp"
                android:textColor="@color/secondary_text"
                android:fontFamily="@font/poppins_regular" />
        </LinearLayout>
    </LinearLayout>

    <!-- Manage Vehicle Data Section -->
    <LinearLayout
        android:id="@+id/manage_vehicle_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@drawable/card_backgrounds"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:elevation="1dp"
        android:translationZ="4dp"
        android:backgroundTint="@color/white"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_car"
            android:layout_marginEnd="12dp"
            app:tint="@color/primary_blue"
            android:contentDescription="Manage Vehicle" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage Vehicle Data"
                android:textSize="16sp"
                android:textColor="@color/primary_text"
                android:fontFamily="@font/poppins_medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add or update vehicle information"
                android:textSize="12sp"
                android:textColor="@color/secondary_text"
                android:fontFamily="@font/poppins_regular" />
        </LinearLayout>
    </LinearLayout>

    <!-- Activity History Section -->
    <LinearLayout
        android:id="@+id/activity_history_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@drawable/card_backgrounds"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:elevation="1dp"
        android:translationZ="4dp"
        android:backgroundTint="@color/white"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_tickets"
            android:layout_marginEnd="12dp"
            app:tint="@color/primary_blue"
            android:contentDescription="Activity History" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Activity History"
                android:textSize="16sp"
                android:textColor="@color/primary_text"
                android:fontFamily="@font/poppins_medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View your past activities and bookings"
                android:textSize="12sp"
                android:textColor="@color/secondary_text"
                android:fontFamily="@font/poppins_regular" />
        </LinearLayout>
    </LinearLayout>

    <!-- About Section -->
    <LinearLayout
        android:id="@+id/about_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@drawable/card_backgrounds"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:elevation="1dp"
        android:translationZ="4dp"
        android:backgroundTint="@color/white"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/info"
            android:layout_marginEnd="12dp"
            app:tint="@color/primary_blue"
            android:contentDescription="About App" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="About"
                android:textSize="16sp"
                android:textColor="@color/primary_text"
                android:fontFamily="@font/poppins_medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Learn more about the app"
                android:textSize="12sp"
                android:textColor="@color/secondary_text"
                android:fontFamily="@font/poppins_regular" />
        </LinearLayout>
    </LinearLayout>

    <!-- Logout Section -->
    <LinearLayout
        android:id="@+id/logout_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@drawable/card_backgrounds"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="24dp"
        android:elevation="1dp"
        android:translationZ="4dp"
        android:backgroundTint="@color/white"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_logout"
            android:layout_marginEnd="12dp"
            app:tint="@color/red"
            android:contentDescription="Logout" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Logout"
                android:textSize="16sp"
                android:textColor="@color/red"
                android:fontFamily="@font/poppins_medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign out of your account"
                android:textSize="12sp"
                android:textColor="@color/secondary_text"
                android:fontFamily="@font/poppins_regular" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>