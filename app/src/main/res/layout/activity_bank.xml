<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:background="#FFFFFF"
        android:elevation="6dp"
        android:clipToPadding="false">

        <!-- Back Button -->
        <ImageView
            android:id="@+id/backButton"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_back"
            android:contentDescription="Back"
            android:layout_marginEnd="20dp"
            app:tint="#333333" />

        <!-- Header Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Link Your Bank Account"
            android:textSize="20sp"
            android:textColor="#1A1A1A"
            android:fontFamily="@font/poppins_bold"/>
    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:paddingHorizontal="0dp"
        android:paddingTop="0dp"
        android:paddingBottom="5dp"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/inputFields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_white_bg"
            android:padding="24dp">

            <!-- Description -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Add your bank account details to receive payments. We’ll validate your account and IFSC code."
                android:textSize="14sp"
                android:textColor="#4A4A4A"
                android:fontFamily="@font/poppins_regular"
                android:paddingBottom="12dp"
                android:lineSpacingExtra="4dp"/>

            <!-- Admin Name -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Admin Name"
                android:textSize="14sp"
                android:textColor="#1A1A1A"
                android:fontFamily="@font/poppins_medium"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"/>

            <EditText
                android:id="@+id/editName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:textColor="#1A1A1A"
                android:hint="Enter your name"
                android:textColorHint="#A0A0A0"
                android:background="@drawable/rounded_edit_text_bg"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_regular"
                android:inputType="text" />

            <!-- Email -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textSize="14sp"
                android:textColor="#1A1A1A"
                android:fontFamily="@font/poppins_medium"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"/>

            <EditText
                android:id="@+id/editEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:textColor="#1A1A1A"
                android:hint="Enter your business email"
                android:textColorHint="#A0A0A0"
                android:background="@drawable/rounded_edit_text_bg"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_regular"
                android:inputType="textEmailAddress" />

            <!-- Phone Number -->


            <!-- Account Holder Name -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Account Holder’s Name"
                android:textSize="14sp"
                android:textColor="#1A1A1A"
                android:fontFamily="@font/poppins_medium"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"/>

            <EditText
                android:id="@+id/editAccountHolder"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:textColor="#1A1A1A"
                android:hint="Enter the name on the account"
                android:textColorHint="#A0A0A0"
                android:background="@drawable/rounded_edit_text_bg"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_regular"/>

            <!-- Account Number -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Account Number"
                android:textSize="14sp"
                android:textColor="#1A1A1A"
                android:fontFamily="@font/poppins_medium"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"/>

            <EditText
                android:id="@+id/editAccountNumber"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:textColor="#1A1A1A"
                android:hint="Enter the account number"
                android:textColorHint="#A0A0A0"
                android:background="@drawable/rounded_edit_text_bg"
                android:paddingHorizontal="16dp"
                android:longClickable="false"
                android:paddingVertical="12dp"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_regular"
                android:inputType="number" />

            <!-- Re-enter Account Number -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Re-enter Account Number"
                android:textSize="14sp"
                android:textColor="#1A1A1A"
                android:fontFamily="@font/poppins_medium"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"/>

            <EditText
                android:id="@+id/editReEnterAccountNumber"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:textColor="#1A1A1A"
                android:hint="Re-enter the account number"
                android:textColorHint="#A0A0A0"
                android:longClickable="false"
                android:background="@drawable/rounded_edit_text_bg"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_regular"
                android:inputType="numberPassword" />

            <!-- IFSC Code -->
            <!-- IFSC Code -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="IFSC Code"
                android:textSize="14sp"
                android:textColor="#1A1A1A"
                android:fontFamily="@font/poppins_medium"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"/>

            <EditText
                android:id="@+id/editIFSC"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:textColor="#1A1A1A"
                android:inputType="textCapCharacters"
                android:hint="Enter the IFSC code"
                android:textColorHint="#A0A0A0"
                android:longClickable="false"
                android:background="@drawable/rounded_edit_text_bg"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_regular" />

            <!-- Save Bank Details Button -->
            <Button
                android:id="@+id/btnSaveBankDetails"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Save Bank Details"
                android:backgroundTint="#2E2E2E"
                android:textColor="#FFFFFF"

                android:fontFamily="@font/poppins_bold"
                app:cornerRadius="12dp"
                app:strokeColor="#E0E0E0"
                app:strokeWidth="1dp"
                android:textSize="16sp"
                android:layout_marginTop="32dp"/>
        </LinearLayout>
    </ScrollView>
</RelativeLayout>