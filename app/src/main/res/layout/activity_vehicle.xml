<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light"
    android:fitsSystemWindows="true">

    <!-- Custom Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/white"
        android:elevation="6dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_back"
            app:tint="@color/text_primary"
            android:contentDescription="Back" />

        <TextView
            android:id="@+id/header_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="35dp"
            android:text="Add Vehicle"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:fontFamily="@font/poppins_bold"
            android:gravity="center"
            android:layout_marginStart="20dp" />
    </LinearLayout>

    <!-- Content Area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Card Container -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                android:layout_marginBottom="28dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/white"
                    android:padding="28dp">

                    <!-- Select Vehicle -->
                    <TextView
                        android:id="@+id/tv_select_vehicle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Select Vehicle"
                        android:visibility="gone"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="@font/poppins_medium"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground"
                        android:layout_marginBottom="20dp" />

                    <!-- Form Title -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Vehicle Details"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:fontFamily="@font/poppins_bold"
                        android:layout_marginBottom="20dp" />

                    <!-- Vehicle Number Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_vehicle_number"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxStrokeColor="@color/primary_selector"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:hintTextColor="@color/text_secondary"
                        app:startIconTint="@color/primary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_vehicle_number"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapCharacters"
                            android:maxLines="1"
                            android:hint="Vehicle Number"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="16sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Vehicle Type Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_vehicle_type"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:hint="Vehicle Type"
                        app:boxStrokeColor="@color/primary_selector"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:hintTextColor="@color/text_primary"
                        app:startIconTint="@color/primary"
                        app:endIconMode="dropdown_menu">

                        <Spinner
                            android:id="@+id/sp_vehicle_type"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@android:color/transparent"
                            android:spinnerMode="dropdown"
                            android:popupBackground="@color/white"
                            android:fontFamily="@font/poppins_regular"
                            android:dropDownVerticalOffset="48dp"
                            android:theme="@style/SpinnerTextStyle" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Save Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:text="Save Vehicle"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:fontFamily="@font/poppins_medium"
                app:backgroundTint="@color/primary"
                app:cornerRadius="16dp"
                style="@style/Widget.MaterialComponents.Button" />

            <!-- Delete Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="12dp"
                android:text="Delete Vehicle"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:visibility="gone"
                android:textColor="@color/red"
                android:fontFamily="@font/poppins_medium"
                app:backgroundTint="@color/white"
                app:strokeColor="@color/red"
                app:strokeWidth="1dp"
                app:cornerRadius="16dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>